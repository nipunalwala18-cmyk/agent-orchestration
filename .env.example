# Application Configuration
APP_ENV=development
SECRET_KEY=949f2b1d5a7d4722883cb0a84e3d36cf793c13ff24729fcfd468160bc72a4ffc

# PostgreSQL Database Configuration
# Use 'postgres' when running inside Docker Compose, and 'localhost' when running backend directly on host
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=platform_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password

# Redis Configuration
# Use 'redis' when running inside Docker Compose, and 'localhost' when running backend directly on host
REDIS_URL=redis://redis:6379/0

# AI/LLM SDK Integration
OPENAI_API_KEY=mock-openai-key-value

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@platform.com
PGADMIN_DEFAULT_PASSWORD=pgadmin_secure_password

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8001

# Google OAuth Keys
GOOGLE_CLIENT_ID=your-google-client-id-here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
